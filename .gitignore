# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ipynb_checkpoints/

# uv / venv  (uv.lock IS tracked — reproducibility)
.venv/

# data & artifacts  (results/ IS tracked — small JSON/PNG artifacts back the docs+figures;
# the *.pt/*.ckpt rules below still exclude any large model dumps that land there)
data/
*.pt
*.ckpt
wandb/
runs/

# build
build/
dist/
*.so
*.pyd

# editors / OS / Claude session data
.vscode/
.idea/
.claude/
.DS_Store
Thumbs.db

# LaTeX build intermediates (kept local everywhere)
*.aux
*.bbl
*.blg
*.log
*.out
*.toc
*.lof
*.lot
*.fls
*.fdb_latexmk
*.synctex.gz

# thesis: the repo ships ONLY the compiled final PDF. All LaTeX source + build (chapters,
# frontmatter, main.tex, references.bib, README, intermediates) stays local and in git history;
# visitors see the finished PDF, not how it was built.
thesis/*
!thesis/Weidenmann_Predictive-Coding-from-Scratch.pdf
